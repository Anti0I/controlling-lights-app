# ── API / Webapp ─────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
DATABASE_URL=sqlite:///./switches.db

# ── MQTT Broker ──────────────────────────────────────────────
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_QOS=1
MQTT_KEEPALIVE=60

# ── Registration / Command timeouts (seconds) ───────────────
REGISTRATION_ACK_TIMEOUT_SECONDS=5.0
COMMAND_ACK_TIMEOUT_SECONDS=5.0

# ── Simulator ────────────────────────────────────────────────
SIMULATOR_DRY_RUN=false
SIMULATOR_ACK_DELAY_MS=50
